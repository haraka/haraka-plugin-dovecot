{
  "name": "haraka-plugin-dovecot",
  "version": "0.3.0",
  "description": "Haraka mail plugin to communicate with Dovecot. Exist Mailbox and SMTP AUTH",
  "author": {
    "name": "Josef Fr�hle",
    "email": "github@josef-froehle.de",
    "url": "https://www.josef-froehle.de/"
  },
  "files": [
    "CHANGELOG.md",
    "config"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "index.js",
  "homepage": "https://github.com/haraka/haraka-plugin-dovecot",
  "keywords": [
    "email",
    "mail",
    "dovecot",
    "plaintext",
    "login",
    "lmtp",
    "auth",
    "mailbox"
  ],
  "bugs": {
    "url": "https://github.com/haraka/haraka-plugin-dovecot/issues"
  },
  "scripts": {
    "test:coverage": "HARAKA_COVERAGE=1 npx c8 npm test",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint": "npx eslint *.js test",
    "lint:fix": "npx eslint *.js test --fix",
    "prettier": "npx prettier . --check",
    "prettier:fix": "npx prettier . --write --log-level=warn",
    "test": "node --test",
    "test:only": "node --test --test-only",
    "test:coverage": "HARAKA_COVERAGE=1 node --test --experimental-test-coverage --test-coverage-exclude=package.json --test-coverage-exclude=test/*.js",
    "test:coverage:lcov": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info test/*.js",
    "versions": "npx npm-dep-mgr check",
    "versions:fix": "npx npm-dep-mgr update"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/haraka/haraka-plugin-dovecot.git"
  },
  "devDependencies": {
    "@haraka/eslint-config": "^2.0.4",
    "haraka-test-fixtures": "~1.5.1"
  },
  "license": "MIT",
  "dependencies": {},
  "optionalDependencies": {},
  "prettier": {
    "singleQuote": true,
    "semi": false
  }
}
